# Build and publish your Backstage image, then set it here.
# Prefer a pinned tag over "latest" for stability.
BACKSTAGE_IMAGE=ghcr.io/backstage/backstage:1.45.1

# Public URL where admins will open Backstage.
BACKSTAGE_BASE_URL=http://backstage.automations.oneacrefund.com

# Local port exposed only on loopback; Nginx reverse-proxies to this.
BACKSTAGE_PORT=7007

# Postgres credentials for Backstage backend.
POSTGRES_USER=backstage
POSTGRES_PASSWORD=1mZxkL4V2b8r
POSTGRES_DB=backstage

# Generate a long random value:
# openssl rand -hex 32
BACKEND_SECRET=1955cbb96b42446ddd8365761b0818653b993e63193c10e40717e1fa78af1786
